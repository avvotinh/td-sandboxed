# Sandboxed Trading System - Git Ignore Configuration
# NFR6: Prevent secrets from being committed

# Environment files (contains secrets)
.env
.env.local
.env.*.local
configs/**/.env
configs/**/.env.local

# Docker volumes and data
data/
*.db
*.sqlite

# Logs
*.log
logs/

# OS files
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# IDE files
.vscode/
.idea/
*.sublime-*

# Build artifacts
bin/
build/
dist/
*.exe

# Go specific
vendor/
*.test
*.out
coverage.html
coverage.txt

# Python specific (for future Epic 2)
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
venv/
env/

# Temporary files
tmp/
temp/
*.tmp

# Benchmark results
benchmark_results/
*.benchmark

# Compliance report artifacts (Epic 10 / D9 — story 10.15).
# ``trading-engine compliance-report`` writes a dated JSON per run to
# ``services/trading-engine/compliance-report-<account>-<YYYY-MM-DD>.json``;
# they are reproducible from the audit log + Redis state so we keep
# them out of git.
compliance-report-*.json
services/trading-engine/compliance-report-*.json

# Stitched dataset manifests are operator-generated artifacts
# referencing absolute parquet paths under data/ (already gitignored).
# Regenerate with scripts/stitch_chunks_to_window.py per
# docs/runbooks/backtest-data-fetch.md.
services/trading-engine/manifests/

# Docker
docker-compose.override.yml

.bmad/
.gemini/
# .claude/ — track shared config (rules, agents, skills, commands), ignore local settings + runtime state
.claude/settings.local.json
.claude/scheduled_tasks.lock
.specify/
specs/
.vscode/

# External reference repos (read-only, not part of Sandboxed)
TradingView-API/