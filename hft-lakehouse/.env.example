# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# TimescaleDB Configuration
TIMESCALEDB_PORT=5432
TIMESCALEDB_USER=postgres
TIMESCALEDB_PASSWORD=postgres
TIMESCALEDB_DB=hft_lakehouse

# TradingView WebSocket Configuration
TRADINGVIEW_WS_URL=wss://data.tradingview.com/socket.io/websocket
TRADINGVIEW_USERNAME=your_tradingview_username
TRADINGVIEW_PASSWORD=your_tradingview_password

# SECURITY WARNING:
# - These are DEFAULT values for local development only
# - NEVER use these credentials in production
# - Change all passwords to strong, unique values before deployment
# - Replace TradingView credentials with your actual account credentials

# Instructions:
# 1. Copy this file to .env: cp .env.example .env
