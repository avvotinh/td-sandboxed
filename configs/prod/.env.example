# Sandboxed Multi-Account Trading System - Production Environment Template
#
# CRITICAL: This is a TEMPLATE file. Copy to .env and configure all values.
# NEVER commit the actual .env file to version control.
#
# NFR6: All secrets must be managed via environment variables
# Version: 1.4 (Story 1.4)
# Last Updated: 2025-12-19

# ============================================================================
# PRE-DEPLOYMENT VERIFICATION CHECKLIST
# ============================================================================
#
# Before deploying to production, verify:
# [ ] All placeholder values replaced with real credentials
# [ ] Database connection tested with SSL enabled
# [ ] Telegram bot token verified working
# [ ] No development credentials remain (search for "dev", "placeholder", "your_")
# [ ] LOG_LEVEL set to warn or error (never debug in production)
# [ ] All passwords are minimum 24 characters with mixed case, numbers, symbols
# [ ] Backup and recovery procedures documented and tested
# [ ] Secrets stored in secure vault (HashiCorp Vault, AWS Secrets Manager)
#
# ============================================================================

# ============================================================================
# INFRASTRUCTURE - Database & Cache
# ============================================================================

# PostgreSQL/TimescaleDB Configuration
# SECURITY: Use minimum 24 character password with mixed case, numbers, symbols
# SECURITY: Enable SSL for database connections in production
POSTGRES_DB=trading
POSTGRES_USER=trading
POSTGRES_PASSWORD=                            # [REQUIRED] Min 24 chars, complex

# For SSL-enabled TimescaleDB connections:
# TIMESCALE_URL=postgres://trading:PASSWORD@host:5432/trading?sslmode=require

# Redis Configuration
# SECURITY: Always use password authentication in production
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=                               # [REQUIRED] Min 24 chars
REDIS_DB=0

# ============================================================================
# TV-API SERVICE - TradingView Data Collector
# ============================================================================

# TradingView Session Credentials
# WARNING: These credentials expire - monitor and rotate regularly
SESSION_ID=                                   # [REQUIRED] From TradingView cookies
SESSION_SIGN=                                 # [REQUIRED] From TradingView cookies

# ============================================================================
# TRADING ENGINE SERVICE - Python/Nautilus Trader
# ============================================================================

# Trading Mode
# CRITICAL: Set to 'live' only when ready for real trading
TRADING_MODE=paper                            # [REQUIRED] paper | live

# ZeroMQ Connection to MT5 Bridge
ZMQ_BRIDGE_HOST=mt5-bridge
ZMQ_PUB_PORT=5556
ZMQ_SUB_PORT=5557

# ============================================================================
# MT5 BRIDGE SERVICE - Rust ZeroMQ Bridge
# ============================================================================

# Rust Logging Configuration
# PRODUCTION: Use warn or error level only - never debug/trace
RUST_LOG=warn                                 # warn | error (NEVER debug in prod)

# ZeroMQ Ports
ZMQ_REQ_PORT=5555

# ============================================================================
# NOTIFICATION SERVICE - Telegram Bot
# ============================================================================

# Telegram Bot Credentials
# CRITICAL: Use dedicated production bot, not development bot
TELEGRAM_BOT_TOKEN=                           # [REQUIRED]
TELEGRAM_CHAT_ID=                             # [REQUIRED]

# ============================================================================
# LOGGING - All Services
# ============================================================================

# PRODUCTION: Never use debug level - exposes sensitive data
LOG_LEVEL=warn                                # warn | error (NEVER debug)
LOG_FORMAT=json                               # json for production log aggregation

# ============================================================================
# APPLICATION TUNING
# ============================================================================

# TV-API Performance Tuning
BATCH_SIZE=100
FLUSH_INTERVAL=1s

# Benchmark Configuration
BENCHMARK_ITERATIONS=1000
BENCHMARK_TARGET_MS=20

# ============================================================================
# PRODUCTION SECURITY REQUIREMENTS (NFR6)
# ============================================================================
#
# Password Requirements:
# - Minimum 24 characters
# - Mixed case letters (A-Z, a-z)
# - Numbers (0-9)
# - Special symbols (!@#$%^&*()_+-=)
# - No dictionary words or common patterns
#
# Secrets Management:
# - Store credentials in HashiCorp Vault or AWS Secrets Manager
# - Never store plain-text credentials in files
# - Rotate all credentials monthly
# - Use separate credentials per environment
# - Audit credential access regularly
#
# Network Security:
# - Enable SSL/TLS for all database connections
# - Use private networks for inter-service communication
# - Implement network segmentation
# - Monitor for unauthorized access attempts
#
# Container Security:
# - Set memory limits to prevent resource exhaustion:
#   - trading-engine: 2GB
#   - mt5-bridge: 512MB
#   - notification: 256MB
# - Run containers as non-root user
# - Use read-only file systems where possible
# - Scan images for vulnerabilities
#
# Monitoring:
# - Enable centralized logging (ELK, Datadog, etc.)
# - Set up alerting for authentication failures
# - Monitor for unusual trading patterns
# - Track credential usage and rotation
#
# ============================================================================

# ============================================================================
# DOCKER COMPOSE PRODUCTION SETTINGS
# ============================================================================
#
# Recommended docker-compose.prod.yml additions:
#
# services:
#   trading-engine:
#     deploy:
#       resources:
#         limits:
#           memory: 2G
#         reservations:
#           memory: 1G
#
#   mt5-bridge:
#     deploy:
#       resources:
#         limits:
#           memory: 512M
#
#   notification:
#     deploy:
#       resources:
#         limits:
#           memory: 256M
#
# ============================================================================
