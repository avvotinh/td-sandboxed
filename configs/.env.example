# Sandboxed Trading System - Environment Configuration Template
# Copy this file to configs/dev/.env and fill in your actual values
# NFR6: All secrets must be managed via environment variables

# ==========================================
# TradingView Credentials (Required)
# ==========================================
# Get these from your browser after logging into TradingView:
# 1. Open DevTools (F12) -> Application -> Cookies
# 2. Find cookies for tradingview.com
# 3. Copy 'sessionid' and 'sessionid_sign' values

SESSION_ID=your_session_id_here
SESSION_SIGN=your_session_sign_here

# ==========================================
# Database Configuration (trading-* naming convention)
# ==========================================
POSTGRES_DB=trading
POSTGRES_USER=trading
POSTGRES_PASSWORD=your_secure_password_here

# ==========================================
# Application Configuration
# ==========================================
# Logging
LOG_LEVEL=info        # debug | info | warn | error
LOG_FORMAT=json       # json | text

# Performance Tuning
BATCH_SIZE=100                # Number of records to batch before insert
FLUSH_INTERVAL=1s             # Time interval to flush batch

# ==========================================
# Benchmark Configuration (Story 1.5)
# ==========================================
BENCHMARK_ITERATIONS=1000     # Number of queries to run in benchmark
BENCHMARK_TARGET_MS=20        # Target latency in milliseconds (NFR1)

# ==========================================
# Redis Configuration (Advanced)
# ==========================================
# These are set automatically in docker-compose
# Override only if needed
# REDIS_URL=redis:6379
# REDIS_PASSWORD=
# REDIS_DB=0

# ==========================================
# TimescaleDB Configuration (Advanced)
# ==========================================
# Connection string is auto-generated in docker-compose
# Override only for external database
# TIMESCALE_URL=postgres://trading:password@trading-timescaledb:5432/trading?sslmode=disable

# ==========================================
# Security Notes (NFR6)
# ==========================================
# - NEVER commit .env file to git
# - Use strong passwords (minimum 16 characters)
# - Rotate credentials regularly
# - Use different passwords for dev/staging/prod
# - Consider using secrets management (Vault, AWS Secrets Manager)
